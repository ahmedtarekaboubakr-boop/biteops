{
  "buildCommand": "cd client && npm install && BUILD_TARGET=vercel npm run build",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://biteops.onrender.com"
  }
}
